{
  "name": "wm-site-starter",
  "version": "1.0.0",
  "description": "A modern Next.js site starter with Tailwind CSS, GSAP animations, and shadcn/ui components",
  "author": "Working Model Inc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/workingmodel/wm-site-starter.git"
  },
  "keywords": [
    "nextjs",
    "next.js",
    "tailwind",
    "gsap",
    "shadcn",
    "starter",
    "template",
    "typescript",
    "react"
  ],
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource/stack-sans-headline": "^5.2.1",
    "@fontsource/stack-sans-text": "^5.2.1",
    "@gsap/react": "^2.1.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "gsap": "^3.12.5",
    "lucide-react": "^0.400.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^2.4.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,jsx,json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.39",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.7",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.5.0"
  }
}
